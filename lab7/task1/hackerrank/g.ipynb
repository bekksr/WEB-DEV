   "source": [
    "from itertools import combinations_with_replacement\n",
    "\n",
    "S, r = input().split()\n",
    "r = int(r)\n",
    "\n",
    "S = ''.join(sorted(S))\n",
    "\n",
    "for combo in combinations_with_replacement(S, r):\n",
    "    print(''.join(combo))"
   ]
  }
