   "source": [
    "def double_char(s):\n",
    "    result = ''\n",
    "    for char in s:\n",
    "        result += char * 2 \n",
    "    return result\n",
    "double_char('The')      \n",
    "double_char('AAbb')     \n",
    "double_char('Hi-There')  "
   ]
