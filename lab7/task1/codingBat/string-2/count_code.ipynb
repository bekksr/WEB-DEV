   "source": [
    "def count_code(s):\n",
    "    count = 0\n",
    "    for i in range(len(s) - 3): \n",
    "        if s[i] == 'c' and s[i+1] == 'o' and s[i+3] == 'e':\n",
    "            count += 1\n",
    "    return count\n",
    "count_code('aaacodebbb')     \n",
    "count_code('codexxcode')     \n",
    "count_code('cozexxcope')     "
   ]
