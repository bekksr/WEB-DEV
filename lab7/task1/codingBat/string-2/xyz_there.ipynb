    "def xyz_there(s):\n",
    "    if s.startswith('xyz'):\n",
    "        return True\n",
    "    for i in range(1, len(s) - 2):\n",
    "        if s[i:i+3] == 'xyz' and s[i-1] != '.':\n",
    "            return True\n",
    "    return False"
