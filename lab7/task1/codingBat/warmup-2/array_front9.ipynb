    "def array_front9(nums):\n",
    "  end = len(nums)\n",
    "  if end > 4:\n",
    "    end = 4\n",
    "  \n",
    "  for i in range(end): \n",
    "    if nums[i] == 9:\n",
    "      return True\n",
    "  return False"
