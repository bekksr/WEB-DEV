   "source": [
    "def front_times(str, n):\n",
    "  front_len = 3\n",
    "  if front_len > len(str):\n",
    "    front_len = len(str)\n",
    "  front = str[:front_len]\n",
    "  \n",
    "  result = \"\"\n",
    "  for i in range(n):\n",
    "    result = result + front\n",
    "  return result"
   ]
  }
