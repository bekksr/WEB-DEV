   "source": [
    "def sum13(nums):\n",
    "    total = 0\n",
    "    skip = False\n",
    "    for n in nums:\n",
    "        if n == 13:\n",
    "            skip = True\n",
    "            continue\n",
    "        if skip:\n",
    "            skip = False\n",
    "            continue\n",
    "        total += n\n",
    "    return total"
   ]
