   "source": [
    "def sum67(nums):\n",
    "    total = 0\n",
    "    in_section = False\n",
    "    for n in nums:\n",
    "        if n == 6:\n",
    "            in_section = True\n",
    "            continue\n",
    "        if in_section:\n",
    "            if n == 7:\n",
    "                in_section = False\n",
    "            continue\n",
    "        total += n\n",
    "    return total"
   ]
  }
