   "source": [
    "def front_back(str):\n",
    "  if len(str) <= 1:\n",
    "    return str\n",
    "  \n",
    "  mid = str[1:len(str)-1] \n",
    "  \n",
    "  return str[len(str)-1] + mid + str[0]"
   ]
  }
